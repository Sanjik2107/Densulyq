# Copy to .env for local backend configuration. Do not commit real .env files.
#
# Leave DATABASE_URL empty to use local SQLite at DB_PATH.
# Use Postgres for Docker/production, for example:
# DATABASE_URL=postgresql://densaulyq:densaulyq@localhost:5432/densaulyq?sslmode=disable
DATABASE_URL=
DB_PATH=medportal.db
CORS_ORIGINS=*
SESSION_TTL_HOURS=24
GEMINI_API_KEY=
